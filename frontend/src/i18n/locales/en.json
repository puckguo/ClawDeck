  "guideTour": {
    "welcome": {
      "title": "Welcome to ClawDeck",
      "description": "A web interface for managing OpenClaw Agents.",
      "features": [
        "View and manage all Agent statuses",
        "Edit Agent core config files (SOUL.md, IDENTITY.md, etc.)",
        "Configure channels (Feishu, Open-ClawChat)",
        "View operation logs",
        "Manage skills and workspaces"
      ],
      "hint": "Click Next to learn about each feature module."
    },
    "steps": {
      "overview": {
        "title": "Overview Panel",
        "description": "Overview panel displays Agent core information:",
        "items": [
          "Basic Info: Assistant ID, name, service port, etc.",
          "Runtime Status: Real-time CPU/memory usage, uptime",
          "Channel Config: Feishu, Open-ClawChat enabled status",
          "Statistics: Installed skills, current rooms, config files count"
        ],
        "hint": "Status auto-refreshes every 5 seconds to ensure you see the latest data."
      },
      "basic": {
        "title": "Basic Configuration",
        "description": "Basic configuration sets Agent basic properties:",
        "items": [
          "Assistant Name: Internal identifier name",
          "Display Name: Name shown externally in chat rooms",
          "Avatar: Select emoji as avatar"
        ],
        "hint": "Note: Assistant ID cannot be modified after creation, it's the unique identifier."
      },
      "channels": {
        "title": "Channel Configuration",
        "description": "Channel configuration manages Agent communication methods:",
        "feishu": {
          "name": "Feishu",
          "items": [
            "Configure AppID and AppSecret",
            "Enable/Disable Feishu bot",
            "Support group and private chat"
          ]
        },
        "chat": {
          "name": "Open-ClawChat",
          "items": [
            "Configure server address",
            "Set Agent display name",
            "Manage joined chat rooms"
          ]
        }
      },
      "files": {
        "title": "Configuration File Management",
        "description": "Configuration files are the core of Agent, click files below to edit:",
        "fileTypes": {
          "soul": "Soul/Personality",
          "identity": "Identity",
          "agents": "Agent Config",
          "tools": "Tool Config",
          "memory": "Long-term Memory"
        },
        "backup": "Auto Backup: System automatically creates backup to .backups/ directory on each modification."
      },
      "logs": {
        "title": "Operation Logs",
        "description": "Operation logs help you monitor Agent running status:",
        "items": [
          "Log Levels: Debug / Info / Warning / Error",
          "Log Types: System / Chat / Error / Audit",
          "Search Filter: Quickly locate logs of interest",
          "Auto Refresh: View latest logs in real-time",
          "Export: Export logs for analysis"
        ],
        "hint": "Logs are displayed in timeline format, newest logs at the top."
      },
      "actions": {
        "title": "Quick Actions",
        "description": "Common operation buttons:",
        "items": [
          "Start: Start Agent service",
          "Stop: Stop Agent service",
          "Restart: Restart Agent service",
          "Delete: Delete Agent (moves to trash)"
        ],
        "hint": "Dangerous operations (delete) have secondary confirmation to avoid accidents."
      },
      "finish": {
        "title": "Get Started",
        "congrats": "Congratulations!",
        "description": "You have learned ClawDeck's core features.",
        "nextSteps": [
          "View overview to understand Agent current status",
          "Edit SOUL.md to customize Agent personality",
          "Configure channels to connect Agent to chat platforms",
          "View logs to monitor running status"
        ],
        "hint": "To view this guide again, click the User Guide button in the top right."
      }
    },
